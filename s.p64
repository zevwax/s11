--[[pod_format="raw",created="2026-04-09 02:43:49",modified="2026-04-20 00:16:26",revision=326]]
--init--
function game_init()
 music(0)
 palt(0, false)
 palt(transparent_color, true)

 screen_width = 240
 screen_height = 135
 character_width = 9
 character_height = 9
 
 sprite_fireball = 192
 
 objects = {}
 signals = {}
 prjctls = {}
 persons = {}
 players = {}
 enemies = {}
 
 main_char_y =
 (screen_height -
 character_height) \ 2
 
 src:load_stage(save_data.curr_stage_name)
 
 main_char = player:new
 (
  {
   x=
   (screen_width -
   character_width) \ 2,
   
   y=main_char_y,
   
   z=-main_char_y
  }
 )
 
	if save_data.name == "mgr-04" then
		spawn_opr93()
	end
	
	function create_block(bx, by)
		bpos =
		{
		x=bx,
		y=by,
		z=400
		}
		local block =
		object:new
		(
		bpos,
		collider:new
		(
		{x=bx, y=by, z=-by},
		{x=0, y=0, z=0},
		{w=8, h=8}
		)
		)
		block_sprt = sprite:new
		(
		bpos,
		220,
		{
		x=0,
		y=0,
		z=0
		}
		)
		add
		(
		block.animator.sprites,
		block_sprt
		)
	end
	
	for x = 0, 232, 8 do create_block(x, 16) end
	for y = 24, 120, 8 do create_block(232, y) end
	for x = 232, 0, -8 do create_block(x, 128) end
	for y = 120, 24, -8 do create_block(0, y) end
end

function spawn_opr93()
	local opr93_x = flr((480/2)/2-(9/2)+0.5)
	if opr93_x < main_char.grid_pos.x then
		opr93_x -= 50
	else
		opr93_x += 50
	end
	opr93 = enemy:new
	(
		{
			x=opr93_x,
			y=main_char.grid_pos.y,
			z=main_char.grid_pos.z
		}
	)
end
