--person--

person = {}
person.__index = person
setmetatable
(
 person,
 {__index = object}
)

function person:new
(grid_pos, name, row_indx)
 local col =
 collider:new
 (
  grid_pos,
  {
   x=1,
   y=0,
   z=0
  },
  {
	 	w=7,
	 	h=9
  }
 )
 local instance =
 object:new
 (
  grid_pos,
  col
 )
 instance.name = name
 instance.eyes_are_open =
 true
 instance.direction =
 3
 instance.left_leg =
 3
 instance.right_leg =
 3
 instance.prev_value_of_moved =
 false
 instance.moved =
 false
 instance.just_stopped =
 false
 instance.ready_to_move =
 true
 instance.next_leg =
 0
 instance.eyes_anim_frame_index =
 15
 instance.feet_anim_frame_index =
 -1
 instance.feet_anim_frame_index =
 -1
 instance.prev_movement_direction =
 {
  x=0,
  y=0,
  z=0
 }
 instance.movement_direction =
 {
  x=0,
  y=0,
  z=0
 }
 
 instance.lt_open = sprite:new
 (
  grid_pos,
  16*row_indx+192,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.lt_clsd = sprite:new
 (
  grid_pos,
  16*row_indx+192+1,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.rt_open = sprite:new
 (
  grid_pos,
  16*row_indx+192+2,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.rt_clsd = sprite:new
 (
  grid_pos,
  16*row_indx+192+3,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.dn_open = sprite:new
 (
  grid_pos,
  16*row_indx+192+4,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.dn_clsd = sprite:new
 (
  grid_pos,
  16*row_indx+192+5,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.up_open = sprite:new
 (
  grid_pos,
  16*row_indx+192+6,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.up_clsd = sprite:new
 (
  grid_pos,
  16*row_indx+192+7,
  {
   x=2,
   y=0,
   z=200
  }
 )
 instance.lt_dn = sprite:new
 (
  grid_pos,
  16*row_indx+192+8,
  {
   x=0,
   y=4,
   z=200
  }
 )
 instance.lt_up = sprite:new
 (
  grid_pos,
  16*row_indx+192+9,
  {
   x=0,
   y=4,
   z=200
  }
 )
 instance.rt_dn = sprite:new
 (
  grid_pos,
  16*row_indx+192+10,
  {
   x=5,
   y=4,
   z=200
  }
 )
 instance.rt_up = sprite:new
 (
  grid_pos,
  16*row_indx+192+11,
  {
   x=5,
   y=4,
   z=200
  }
 )
 instance.shadow = sprite:new
 (
  grid_pos,
  204,
  {
   x=1,
   y=8,
   z=600
  }
 )
 instance.view = sprite:new
 (
  grid_pos,
  205,
  {
   x=-90-198*2,
   y=-90-198*2,
   z=0
  }
 )
 instance.mark = sprite:new
 (
  grid_pos,
  222,
  {
   x=2,
   y=3,
   z=-200
  }
 )
 setmetatable(instance, person)
 add(persons, instance)
 return instance
end

--update xtras--

function person:update()
 self:update_pos()
 self.just_stopped =
 	self.prev_value_of_moved ==
 	true and not self.moved
 if self.just_stopped then
 	self.ready_to_move = false
 end
 self:update_eyes_anim_frame_index()
 self:update_frame_index()
	self:update_head()
	self:update_eyes()
	self:update_legs()
	self.prev_value_of_moved =
	self.moved
	self.animator.sprites = {}
	self:load_head_sprt()
	self:load_lt_foot_sprt()
	self:load_rt_foot_sprt()
	self:load_shadow_sprt()
	if self.name[6] == "4" then
		self:load_view_sprt()
	end
--	self:load_mark_sprt()
	self.prev_movement_direction =
	self.movement_direction
end

function person:update_pos()

 local start_pos =
 	clone(self.grid_pos)
 
 if
  self.movement_direction.x
  == -1
 then
  self:move_lt()
  if self.collider:check()
  then self:move_rt()
  end
 elseif
  self.movement_direction.x
  == 1
 then
  self:move_rt()
  if self.collider:check()
  then self:move_lt()
  end
 end
 
 if
  self.movement_direction.y
  == -1
 then
  self:move_up()
  if self.collider:check()
  then self:move_dn()
  end
 elseif
  self.movement_direction.y
  == 1
 then
  self:move_dn()
  if self.collider:check()
  then self:move_up()
  end
 end
 
 self.moved =
		not are_equal
		(
		 self.grid_pos,
		 start_pos
		)
end

function person:update_eyes_anim_frame_index()
 self.eyes_anim_frame_index += 1
 if self.eyes_anim_frame_index
 > 100 + d(101)
 then
 	self.eyes_anim_frame_index = 0
 end
end

function person:update_frame_index()
 if not self.moved and
 not self.ready_to_move then
  self:get_ready_to_move()
	elseif self.moved then
	 self.feet_anim_frame_index += 1
	 if self.feet_anim_frame_index > 7
  then
	 	self.feet_anim_frame_index = 0
	 end
 end
end

function person:get_ready_to_move()
  self.pos_anim_frame_index = -1
  self.feet_anim_frame_index = -1
  self:change_leg()
  self.ready_to_move = true
end

function person:update_head()
 if
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=-1,
	   y=0,
	   z=0
	  }
	 )
 then
  self.direction = 0
 elseif
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=1,
	   y=0,
	   z=0
	  }
	 )
 then
  self.direction = 1
 elseif
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=-1,
	   y=-1,
	   z=0
	  }
	 )
	 or
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=0,
	   y=-1,
	   z=0
	  }
	 )
	 or
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=1,
	   y=-1,
	   z=0
	  }
	 )
 then
  self.direction = 2
 elseif
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=-1,
	   y=1,
	   z=0
	  }
	 )
	 or
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=0,
	   y=1,
	   z=0
	  }
	 )
	 or
	 are_equal
	 (
	  self.movement_direction,
	  {
	   x=1,
	   y=1,
	   z=0
	  }
	 )
 then
  self.direction = 3
 end
end

function person:update_eyes()
 if
  self.eyes_anim_frame_index
  > 15
 then
  self.eyes_are_open = true
 elseif
  self.eyes_anim_frame_index
  <= 15
 then
  self.eyes_are_open = false
 end
end

function person:update_legs()
 self:update_left_leg()
 self:update_right_leg()
 if self.moved and
 self.feet_anim_frame_index
 == 7
 then
  self:change_leg()
 end
end

function person:change_leg()
	if self.next_leg == 0
	then
	 self.next_leg = 1
	elseif self.next_leg == 1
	then
	 self.next_leg = 0
	end
end

function person:update_left_leg()
 if not self.moved
 then
  self.left_leg = 3
 elseif self.moved
 then
 	if self.next_leg == 0
 	then
   self.left_leg = 2
  elseif self.next_leg == 1
  then
   self.left_leg = 3
  end
 end
end

function person:update_right_leg()
 if not self.moved then
  self.right_leg = 3
 elseif self.moved then
 	if self.next_leg == 0 then
   self.right_leg = 3
  elseif self.next_leg == 1 then
   self.right_leg = 2
  end
 end
end

function person:load_head_sprt()
 if self.direction == 0
 then
  if self.eyes_are_open then
   add
   (
		  self.animator.sprites,
		  self.lt_open
   )
  else
   add
   (
		  self.animator.sprites,
		  self.lt_clsd
   )
		end
 elseif self.direction == 1
 then
  if self.eyes_are_open then
   add
   (
		  self.animator.sprites,
		  self.rt_open
   )
  else
   add
   (
		  self.animator.sprites,
		  self.rt_clsd
   )
		end
 elseif self.direction == 3
 then
  if self.eyes_are_open then
   add
   (
		  self.animator.sprites,
		  self.dn_open
   )
  else
   add
   (
		  self.animator.sprites,
		  self.dn_clsd
   )
		end
 elseif self.direction == 2
 then
  if self.eyes_are_open then
   add
   (
		  self.animator.sprites,
		  self.up_open
   )
  else
   add
   (
		  self.animator.sprites,
		  self.up_clsd
   )
		end
 end
end

function person:load_lt_foot_sprt()
 if self.left_leg == 3
 then
   add
   (
		  self.animator.sprites,
		  self.lt_dn
   )
 elseif self.left_leg == 2
 then
   add
   (
		  self.animator.sprites,
		  self.lt_up
   )
 end
end

function person:load_rt_foot_sprt()
 if self.right_leg == 3
 then
   add
   (
		  self.animator.sprites,
		  self.rt_dn
   )
 elseif self.right_leg == 2
 then
   add
   (
		  self.animator.sprites,
		  self.rt_up
   )
 end
end

function person:load_shadow_sprt()
 add
  (
	  self.animator.sprites,
	  self.shadow
  )
end

function person:load_view_sprt()
 add
  (
	  self.animator.sprites,
	  self.view
  )
end

function person:load_mark_sprt()
 add
  (
	  self.animator.sprites,
	  self.mark
  )
end

function person:draw_name()
	write(self.name, self.grid_pos.x*2-3, self.grid_pos.y*2-7, 7)
end
:: t/player.lua
--[[pod_format="raw",created="2026-04-09 02:41:51",modified="2026-04-19 23:56:16",revision=50]]
--player / enemy--

--player--

player = {}
player.__index = player
setmetatable
(
 player,
 {__index = person}
)
function player:new(grid_pos)
 local instance =
 person:new(grid_pos, save_data.name, save_data.row_indx)
 setmetatable(instance, player)
 add(players, instance)
 return instance
end

function player:get_input()
 self.movement_direction.x = 0
 self.movement_direction.y = 0

 if btn(0) or key("a")
 then
  self.movement_direction.x
  -= 1
 end
 
 if btn(1) or key("d")
 then
  self.movement_direction.x
  += 1
 end
 
 if btn(2) or key("w")
 then
  self.movement_direction.y
  -= 1
 end
 
 if btn(3) or key("s")
 then
  self.movement_direction.y
  += 1
 end
end

--enemy--

enemy = {}
enemy.__index = enemy
setmetatable
(
 enemy,
 {__index = person}
)
function enemy:new(grid_pos)
 local instance =
 person:new(grid_pos, "opr-93", 0)
 instance.move_timer = 0
 setmetatable(instance, enemy)
 add(enemies, instance)
 return instance
end

function enemy:get_input()
 if self.move_timer <= 0 then
  self.movement_direction.x = 0
  self.movement_direction.y = 0
  
  local dir = flr(rnd(8))
  
  if dir == 0 then 
   self.movement_direction.x = -1
  elseif dir == 1 then 
   self.movement_direction.x = 1
  elseif dir == 2 then 
   self.movement_direction.y = -1
  elseif dir == 3 then 
   self.movement_direction.y = 1
  elseif dir == 4 then
   self.movement_direction.x = -1
   self.movement_direction.y = -1
  elseif dir == 5 then
   self.movement_direction.x = 1
   self.movement_direction.y = -1
  elseif dir == 6 then
   self.movement_direction.x = -1
   self.movement_direction.y = 1
  elseif dir == 7 then
   self.movement_direction.x = 1
   self.movement_direction.y = 1
  end
  
  self.move_timer = 15 + flr(rnd(30))
 else
  self.move_timer -= 1
 end
end
:: t/signal.lua
--[[pod_format="raw",created="2026-04-18 04:43:18",modified="2026-04-22 15:50:52",revision=795]]
signal = {}
signal.__index = signal
setmetatable
(
 signal,
 {__index = object}
)

function signal:new
(grid_pos, clr, txt, pst_coll_stg, pst_send_stg, pst_wipe_stg)
 local col =
 collider:new
 (
  grid_pos,
  {
   x=-1,
   y=-1,
   z=0
  },
  {
	 	w=4,
	 	h=4
  }
 )
 local instance =
 object:new
 (
  grid_pos,
  col
 )
 instance.clr = clr
 instance.txt = txt
 instance.pst_coll_stg = pst_coll_stg
 instance.pst_send_stg = pst_send_stg
 instance.pst_wipe_stg = pst_wipe_stg
 instance.circs = {}
 instance.start_time = t()
 instance.last_spawn_t = nil
 setmetatable(instance, signal)
 add(signals, instance)
 return instance
end
function signal:x()
	return self.grid_pos.x*2-1
end
function signal:y()
	return self.grid_pos.y*2-1
end
function signal:update()
	if self.circs[1] and self.circs[1].deleted then return end
	if #self.circs < 10 and (#self.circs == 0 or self.circs[#self.circs].frame_index > 60) then-- ((t() - self.start_time) % 2) < 0.1 then
		if self.last_spawn_t == nil or t() - self.last_spawn_t > 1 then
			add(self.circs, o:new({x=self:x(), y=self:y()}, 0, self.clr, 1))
			self.last_spawn_t = t()
		end
	end
end
function signal:collect()
	local last_circ_clr = 7
--	del(signals, self)
	add(self.circs, o:new({x=self.grid_pos.x*2-1, y=self.grid_pos.y*2-1}, 0, last_circ_clr, 5))
	self:delete()
	
	for l in all(data.logs) do
		l.indx += 1
	end
	
	if self.clr == 8 then
		src.curr_stage_name = src.stages.reboot_asap
		for s in all(signals) do
			s:delete()
		end
		for l in all(data.logs) do
			l:destroy(logs_canvas)
		end
	end
	
	log:new
	(
		logs_canvas,
		{
			x=0,
			y=0,
			z=10
		},
		1,
		self.clr,
		{self.txt},
		self.pst_send_stg,
		self.pst_wipe_stg
	)
	save_data.num_of_logs += 1
	
	if self.clr != 8 then
		save_data.signals_received += 1
		if save_data.signals_received == 10 then
			src:promote()
		end
		add(save_data.log_mrk_vals, tostring(dt()))
		add(save_data.log_clr_vals, self.clr)
		add(save_data.log_lbl_vals, self.txt)
		store(save_file, save_data)
		nice_text:new
		(
			habits_canvas,
			self:x(),
			self:y(),
			"ready to send"
		)
		if self.pst_coll_stg then
			src:start_stage(self.pst_coll_stg)
		end
	end
end
function signal:delete()
	del(objects, self)
	for c in all(self.circs) do
		c.deleted = true
	end
end
:: t/sprite.lua
--[[pod_format="raw",created="2026-04-09 02:50:50",modified="2026-04-18 17:35:05",revision=66]]
--sprite / animator--

--sprite--

sprite = {}
sprite.__index = sprite
function sprite:new
(parent_pos, index, offset)

 local instance = {}
 
 instance.parent_pos =
 parent_pos
 
 instance.index =
 index
 
 instance.offset =
 offset
 
 instance.sprite_pos =
 {
  x=0,
  y=0,
  z=0
 }
 
 setmetatable(instance, sprite)
 return instance
 
end

function sprite:pos()
 self.sprite_pos.x =
 self.parent_pos.x +
 self.offset.x
 
 self.sprite_pos.y =
 self.parent_pos.y +
 self.offset.y
 
 self.sprite_pos.z =
 self.parent_pos.z +
 self.offset.z
 
 return self.sprite_pos
end

function sprite:draw()
	if self.index == 205 then
		spr(
		self.index,
		self.parent_pos.x*2+self.offset.x,
		self.parent_pos.y*2+self.offset.y
		)
	else
		local x_start = self:pos().x * 2
		local y_start = self:pos().y * 2
		local s = get_spr(self.index)
		
		for py = 0, 7 do
		  for px = 0, 7 do
		    local col = s:get(px, py)
		    
		    if col ~= transparent_color then
		      local dx = x_start + px * 2
		      local dy = y_start + py * 2
		      rectfill(dx, dy, dx + 1, dy + 1, col)
		    end
		  end
		end
	end
end



--animator--

animator = {}
animator.__index = animator
function animator:new
(obj_grid_pos, offset)
 local instance = {}
 instance.obj_grid_pos =
 obj_grid_pos
 instance.offset = offset
 instance.sprites = {}
 setmetatable(instance, animator)
 return instance
end

function animator:anim_pos()
 return
  {
   x=self.obj_grid_pos.x
   +self.offset.x,
   
   y=self.obj_grid_pos.y
   +self.offset.y,
   
   z=self.obj_grid_pos.z
   +self.offset.z
  }
end
