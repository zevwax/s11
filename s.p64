:: launch_anim.lua
--[[pod_format="raw",created="2026-04-18 16:28:59",modified="2026-04-18 17:48:14",revision=59]]
local colors = {
	bg     = 0,
	text   = 6,
	dim    = 5,
	accent = 6,
	ui     = 6,
	brand  = 1,
	glow   = 6
}

local state = "logging"
local timer = 0
local logs = {}
local log_index = 1
local progress = 0

local boot_messages = {
	"SIGNAL BIOS V2.3.0",
	"COPYRIGHT (C) 1994 DNC FOUNDATION",
	"------------------------------",
	"CPU: SIG-68000 @ 33MHZ",
	"RAM: 4096KB OK",
	"VRAM: 1024KB OK",
	"MOUNTING DEV/SDA1...",
	"INITIALIZING KERNEL...",
	"LOADING DRIVERS: DISK, MOUSE, NET",
	"STARTING SIGNALOS GUI..."
}

function anim_init()
	cls()
end

function anim_update()
	timer += 1
	
	if state == "logging" then
		if timer % 15 == 0 and log_index <= #boot_messages then
			add(logs, boot_messages[log_index])
			log_index += 1
		elseif log_index > #boot_messages then
			state = "loading"
			timer = 0
		end
	
	elseif state == "loading" then
		progress += 0.015
		if progress >= 1 then
			state = "ready"
			timer = 0
		end

	elseif state == "ready" then
		if timer > 60 then
			state = "finished"
		end
	end
end

function anim_draw()
	cls(colors.bg)
	
	if state == "logging" or state == "loading" then
		for i, msg in ipairs(logs) do
			print(msg, 10, 10 + (i * 10), colors.text)
		end
	end
	
	if state == "loading" then
		local bx, by, bw, bh = 140, 200, 200, 10
		rect(bx, by, bx + bw, by + bh, colors.dim)
		rectfill(bx + 2, by + 2, bx + 2 + (progress * (bw - 4)), by + bh - 2, colors.accent)
		
		local chars = {"|", "/", "-", "\\"}
		local spin = chars[flr(timer / 4) % 4 + 1]
		print("SYSTEM READY " .. spin, 205, 185, colors.ui)
	end
	
	if state == "ready" then
		local cx, cy = 240, 135
		local pulse = sin(timer / 60) * 5
		
--		rectfill(0, 0, 479, cy + 40, colors.brand)
		circ(cx, cy, 30 + pulse, colors.glow)
		
		local title = "SignalOS"
		print(title, cx - (#title * 2)-2, cy - 2, colors.text)
		
--		if timer % 40 < 20 then
--			print("_", cx + 24, cy - 2, colors.text)
--		end
	end
end

function skip_anim()
	state = "finished"
end
function anim_isnt_ready()
	return state != "finished"
end
