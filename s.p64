:: t/collider.lua
--[[pod_format="raw",created="2026-04-09 02:40:02",modified="2026-04-18 06:35:20",revision=30]]
--collider--

collider = {}
collider.__index = collider
function collider:new
(obj_grid_pos, offset, size)
 local instance = {}
 instance.obj_grid_pos =
 obj_grid_pos
 instance.offset = offset
 instance.size = size
 setmetatable(instance, collider)
 return instance
end

function collider:col_pos()
 return
  {
   x=self.obj_grid_pos.x
   +self.offset.x,
   
   y=self.obj_grid_pos.y
   +self.offset.y,
   
   z=self.obj_grid_pos.z
   +self.offset.z
  }
end

function collider:check()

 local lt_side =
 self:col_pos().x
 
 local rt_side =
 lt_side +
 self.size.w
 
 local up_side =
 self:col_pos().y
 
 local dn_side =
 up_side +
 self.size.h
 
 result = false
 
 for o in all(objects) do
  
  local col = o.collider
  
  if col != self then
  
		 local col_lt_side =
		 col:col_pos().x
		 
		 local col_rt_side =
		 col_lt_side +
		 col.size.w
		 
		 local col_up_side =
		 col:col_pos().y
		 
		 local col_dn_side =
		 col_up_side +
		 col.size.h
	  
	  local horizontal_overlapping =
	  lt_side < col_rt_side
	  and
	  col_lt_side < rt_side
	  
	  local vertical_overlapping =
	  dn_side > col_up_side
	  and
	  col_dn_side > up_side
	  
	  local collision =
	  horizontal_overlapping and
	  vertical_overlapping
	  
	  if collision then
			if getmetatable(o) == signal then
				o:collect()
			else
				result = true
			end
		end
	end
end
 
 return result
 
end
:: t/draw_xtras.lua
--[[pod_format="raw",created="2026-04-09 02:43:18",modified="2026-04-18 09:34:40",revision=5]]
function draw_names()
	for p in all(persons) do
		p:draw_name()
	end
end

function draw_all_sprts()
 local sprts = {}
	for o in all(objects) do
		for s in
		all(o.animator.sprites) do
	  add
	  (
	   sprts,
	   s
	  )
	 end
 end
 
 sort_sprites(sprts)
 
	for s in all(sprts) do
  s:draw()
 end
end

function get_k_of_max_z_obj(objs)
	k_of_max_z_obj = nil
	for k, v in pairs(objs) do
		if k_of_max_z_obj == nil
		then k_of_max_z_obj = k
		elseif v.pos.z > objs[k_of_max_z_obj].pos.z
		then k_of_max_z_obj = k end
	end
	return k_of_max_z_obj
end

function get_v_of_max_z_obj(objs)
	v_of_max_z_obj = nil
	for k, v in pairs(objs) do
		if v_of_max_z_obj == nil
		then v_of_max_z_obj = v
		elseif v.pos.z > v_of_max_z_obj.pos.z
		then v_of_max_z_obj = v end
	end
	return v_of_max_z_obj
end

function debug()
 print
 (
  "grid_pos",
  63,
  0,
  2
 )
 print
 (
  "x: "..(flr(main_char.grid_pos.x * 1000) / 1000),
  63,
  6,
  2
 )
 print
 (
  "y: "..(flr(main_char.grid_pos.y * 1000) / 1000),
  63,
  12,
  2
 )
 print
 (
  "z: "..(flr(main_char.grid_pos.z * 1000) / 1000),
  63,
  18,
  2
 )
end
