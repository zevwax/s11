--[[pod_format="raw",created="2026-04-18 11:24:33",modified="2026-04-22 15:51:31",revision=481]]
log = {}
log.__index = log
function log:new(cnvs, pos, indx, clr, lbl, pst_send_stg, pst_wipe_stg)
	local instance = {}
	cnvs:add_el(instance)
	instance.pos = pos
	instance.indx = indx
	instance.clr = clr
	instance.initial_contents = lbl[1]
	instance.lbl = lbl
	instance.pst_send_stg = pst_send_stg
	instance.pst_wipe_stg = pst_wipe_stg
	instance.is_active = true
	instance.time_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=0,
			y=0
		},
		79,
		16,
		function()
		end,
		nil,
		{tostring(dt())},
		nil,
		false
	)
	instance.clr_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=79,
			y=0
		},
		16,
		16,
		function()
		end,
		instance.clr,
		{""},
		nil,
		false
	)
	instance.main_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=79+16,
			y=0
		},
		312,
		16,
		function()
		end,
		nil,
		lbl,
		nil,
		false
	)
	instance.edit_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=79+16+312,
			y=0
		},
		19,
		16,
		function()
			lat_keys_textbox.lbl = lbl
			input_str = lbl
			lat_keys_canvas:switch_to()
		end,
		nil,
		{"edit"},
		nil
	)
	instance.exp_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=79+16+312+19,
			y=0
		},
		19,
		16,
		function()
			if instance.is_active then
				save_data.log_is_active_vals[save_data.num_of_logs + 1 - instance.indx]
				= false
				store(save_file, save_data)
				instance:disable()
				
				if (instance.initial_contents == instance.lbl[1]) then
					if instance.pst_send_stg then
						src:start_stage(instance.pst_send_stg)
					end
				else
					if instance.pst_wipe_stg then
						src:start_stage(instance.pst_wipe_stg)
					end
				end
			end
		end,
		nil,
		{"send"},
		nil
	)
	instance.del_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=79+16+312+19+19,
			y=0
		},
		19,
		16,
		function()
			if instance.pst_wipe_stg then
				src:start_stage(instance.pst_wipe_stg)
			end
			save_data.num_of_logs -= 1
			deli(save_data.log_mrk_vals, save_data.num_of_logs+1-instance.indx)
			deli(save_data.log_clr_vals, save_data.num_of_logs+1-instance.indx)
			deli(save_data.log_lbl_vals, save_data.num_of_logs+1-instance.indx)
			store(save_file, save_data)
			for l in all(data.logs) do
				if l.indx > instance.indx then
					l.indx -= 1
				end
			end
			instance:destroy(cnvs)
		end,
		nil,
		{"wipe"},
		nil
	)
	add(data.elements, instance)
	add(data.log_set, instance)
	add(data.logs, instance)
	setmetatable(instance, log)
	return instance
end
function log:update()
	local top = 32
	local height = 16
	local max_number_per_screen = flr((270 - 32) / height + 0.5)
	local _count = #data.logs-max_number_per_screen
	if _count < 0
		then _count = 0
		end
	self.pos.x = 0
	self.pos.y = top+(self.indx-1)*height-logs_slider.value*(height*_count)
	
	if input_str then
		local lbl_capacity = 71
		local byte_pos = utf8.offset(input_str[1], lbl_capacity + 1)
		if byte_pos then
			self.lbl[1] = string.sub(self.lbl[1], 1, byte_pos - 1)
		end
	end
end
function log:draw()
end
function log:disable()
	self.is_active = false
	self.edit_btn.lbl = {""}
	self.exp_btn.lbl = {"sent"}
	self.del_btn.lbl = {""}
	self.edit_btn:disable()
	self.exp_btn:disable()
	self.del_btn:disable()
end
function log:destroy(cnvs)
	local objs = {
		self.time_btn,
		self.clr_btn,
		self.main_btn,
		self.edit_btn,
		self.exp_btn,
		self.del_btn,
		self
	}

	for o in all(objs) do
		del(data.elements, o)
		del(data.buttons, o)
		del(data.habits, o)
		del(data.logs, o)
		del(data.log_set, o)
		cnvs:del_el(o)
	end
	
	for k, v in pairs(self) do
		self[k] = nil
	end
end
