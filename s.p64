	setmetatable(instance, message)
	return instance
end
function message:update()
	local top = 32
	local height = 16
	local max_number_per_screen = flr((270 - 32) / height + 0.5)
	local _count = #data.letters-max_number_per_screen
	if _count < 0
		then _count = 0
		end
	self.pos.x = 0
	self.pos.y = top+(self.indx-1)*height-payout_node_slider.value*(height*_count)
end
function message:draw()
end
