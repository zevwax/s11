:: objs/compensation.lua
--[[pod_format="raw",created="2026-04-18 11:26:37",modified="2026-04-19 18:25:56",revision=166]]
compensation = {}
compensation.__index = compensation
function compensation:new(cnvs, pos, indx, amount, lbl)
	local instance = {}
	cnvs:add_el(instance)
	instance.pos = pos
	instance.indx = indx
	instance.amount = amount
	instance.lbl = lbl
	instance.is_active = true
	instance.time_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=0,
			y=0
		},
		90,
		16,
		function()
		end,
		nil,
		{tostring(date())},
		nil,
		false
	)
	instance.amount_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=90,
			y=0
		},
		45,
		16,
		function()
		end,
		nil,
		{instance.amount},
		nil,
		false
	)
	instance.main_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=135,
			y=0
		},
		284,
		16,
		function()
		end,
		nil,
		lbl,
		nil,
		false
	)
	instance.claim_btn =
	button:new
	(
		cnvs,
		instance.pos,
		{
			x=419,
			y=0
		},
		45,
		16,
		function()
			if instance.is_active then
				save_data.bux += instance.amount
				save_data.letter_is_active_vals[save_data.num_of_letters + 1 - instance.indx]
				= false
				store(save_file, save_data)
				instance:disable()
				
				local mx, my, mb = mouse()
				nice_text:new
				(
					payout_node_canvas,
					mx,
					my,
					"+ bux "..instance.amount
				)
			end
		end,
		nil,
		{"accept"},
		nil
	)
	add(data.elements, instance)
	add(data.letters, instance)
	setmetatable(instance, compensation)
	return instance
end
function compensation:disable()
	self.is_active = false
	self.claim_btn.lbl = {"accepted"}
	self.claim_btn:disable()
end
function compensation:update()
	local top = 32
	local height = 16
	local max_number_per_screen = flr((270 - 32) / height + 0.5)
	local _count = #data.letters-max_number_per_screen
	if _count < 0
		then _count = 0
		end
	self.pos.x = 0
	self.pos.y = top+(self.indx-1)*height-payout_node_slider.value*(height*_count)
end
function compensation:draw()
end
