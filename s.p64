--[[pod_format="raw",created="2026-04-18 13:14:57",modified="2026-04-20 01:24:01",revision=2024]]
source = {}
source.__index = source
function source:new()
	local instance = {}
	instance.curr_stage_name = ""
	instance.stages =
	{
		bfr_pre_lime="switch to the radar tab and intercept a signal",
		bfr_lime="switch to the radar tab and intercept a signal ",
		bfr_xport="switch to the signal log tab and send a signal log",
		send_bfr_purple="intercept a signal",
		send_bfr_cyan="intercept a signal ",
		send_bfr_blue="intercept a signal  ",
		send_bfr_pink="intercept a signal   ",
		send_bfr_yellow="intercept a signal    ",
		send_bfr_pre_green="intercept a signal     ",
		send_bfr_green="intercept a signal      ",
		send_bfr_orange="intercept a signal       ",
		send_bfr_last="intercept a signal        ",
		send_bfr_xport="you won! thank you for playing!",
		wipe_bfr_purple="intercept a signal          ",
		wipe_bfr_cyan="intercept a signal           ",
		wipe_bfr_blue="intercept a signal            ",
		wipe_bfr_pink="intercept a signal             ",
		wipe_bfr_yellow="intercept a signal              ",
		wipe_bfr_pre_green="intercept a signal               ",
		wipe_bfr_green="intercept a signal                ",
		wipe_bfr_orange="intercept a signal                 ",
		wipe_bfr_last="intercept a signal                  ",
		wipe_bfr_xport="you won! thank you for playing! ",
		reboot_asap="reboot the signalos"
	}
	instance.lets =
	{
		welcome1="we are pleased to welcome you back, operator-04!",
		welcome2="in the radar tab, intercept signals using the arrow keys.",
		welcome3="send signal logs in the signal log tab.",
		protip="pro tip: use the space key to switch between tabs.",
		gj="good job! you may accept your compensation.",
		bonus="outstanding performance! you may accept your bonus.",
		notice="do not edit or wipe logs. any distortion or loss of information is unacceptable.",
		promoted="congratulations! you have been promoted to manager. compensation has been increased.",
		attention="attention! do not accept red signals, as they may contain malware.",
		location_request="a bonus is available for any information regarding the location of sierra 1-1."
	}
	instance.happy_end = nil
	setmetatable(instance, source)
	return instance
end
function source:start_stage(stage_name)
	if stage_name == self.stages.bfr_pre_lime then
		local l = "l"
	elseif stage_name == self.stages.bfr_lime then
		self:send_message(self.lets.welcome3)
		self:send_message(self.lets.welcome2)
		self:send_message(self.lets.welcome1)
	elseif stage_name == self.stages.bfr_xport then
		local l = "l"
	elseif stage_name == self.stages.send_bfr_purple then
		self:send_message(self.lets.protip)
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.send_bfr_cyan then
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.send_bfr_blue then
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.send_bfr_pink then
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.send_bfr_yellow then
		self:send_compensation(self.lets.gj)
		self:send_message(self.lets.location_request)
		self:send_message(self.lets.attention)
	elseif stage_name == self.stages.send_bfr_green then
		self:send_bonus(self.lets.bonus)
	elseif stage_name == self.stages.send_bfr_orange then
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.send_bfr_last then
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.send_bfr_xport then
		self:send_compensation(self.lets.gj)
	elseif stage_name == self.stages.wipe_bfr_purple then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_cyan then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_blue then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_pink then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_yellow then
		self:send_message(self.lets.notice)
		self:send_message(self.lets.location_request)
		self:send_message(self.lets.attention)
	elseif stage_name == self.stages.wipe_bfr_green then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_orange then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_last then
		self:send_message(self.lets.notice)
	elseif stage_name == self.stages.wipe_bfr_xport then
		self:send_message(self.lets.notice)
	end
	self:load_stage(stage_name)
end
function source:load_stage(stage_name)
	self.curr_stage_name = stage_name
	save_data.curr_stage_name = stage_name
	store(save_file, save_data)
	if stage_name == self.stages.bfr_pre_lime then
		start_timer_to_lime_stage()
	elseif stage_name == self.stages.bfr_lime then
		self:create_signal
		(
			8+9,
			8*3+9,
			11,
			"its s13rra. i d0nt want th1s, charl1e!!",
			self.stages.bfr_xport,--the stage we want to switch to RIGHT AFTER collect it
			self.stages.send_bfr_purple,--the stage we want to switch to RIGHT AFTER send it
			self.stages.wipe_bfr_purple--the stage we want to switch to RIGHT AFTER wipe it
		)
	elseif stage_name == self.stages.send_bfr_purple or
	stage_name == self.stages.wipe_bfr_purple then
		self:create_signal
		(
			flr(480/2/2+0.5),
			flr(270/2/2+0.5),
			16,
			"10100111#1#10##d0n#7#137#th3m#k111#h3r##1#10#001#1110100",
			self.stages.bfr_xport,
			self.stages.send_bfr_cyan,
			self.stages.wipe_bfr_cyan
		)
	elseif stage_name == self.stages.send_bfr_cyan or
	stage_name == self.stages.wipe_bfr_cyan then
		self:create_signal
		(
			flr(480/2+0.5)-(8+9),
			flr(270/2+0.5)-(8+9),
			17,
			"s1erra, it's ch4rlie two-three. reques7ing your full call si9n. over.",
			self.stages.bfr_xport,
			self.stages.send_bfr_blue,
			self.stages.wipe_bfr_blue
		)
	elseif stage_name == self.stages.send_bfr_blue or
	stage_name == self.stages.wipe_bfr_blue then
		self:create_signal
		(
			8+9,
			flr(270/2+0.5)-(8+9),
			12,
			"si3rra one-o#e.. we can't k3ep liv1ng like this!! i n3ed y0u..",
			self.stages.bfr_xport,
			self.stages.send_bfr_pink,
			self.stages.wipe_bfr_pink
		)
		self:create_signal
		(
			8+9,
			8*3+9,
			3,
			"1010011101001110#001#11110#001#11111#10110#010#010#001#111111100111#1",
			nil,
			nil,
			nil
		)
	elseif stage_name == self.stages.send_bfr_pink or
	stage_name == self.stages.wipe_bfr_pink then
		self:create_signal
		(
			flr(480/2+0.5)-(8+9),
			8*3+9,
			26,
			"sierra, it's charl1e two-three. listen-in possible. don't send the da7a. t#3y#re k##",
			self.stages.bfr_xport,
			self.stages.send_bfr_yellow,
			self.stages.wipe_bfr_yellow
		)
	elseif stage_name == self.stages.send_bfr_yellow or
	stage_name == self.stages.wipe_bfr_yellow then
		self:create_signal
		(
			8+9,
			8*3+9,
			10,
			"42.0264, -87.7011",
			self.stages.bfr_xport,
			self.stages.send_bfr_pre_green,
			self.stages.wipe_bfr_pre_green
		)
		self:create_signal
		(
			flr(480/2+0.5)-(8+9),
			flr(270/2+0.5)-(8+9),
			8,
			"[ critical error: system corruption detected. reboot asap !!! ]",
			self.stages.bfr_xport,
			self.stages.send_bfr_pre_green,
			self.stages.wipe_bfr_pre_green
		)
	elseif stage_name == self.stages.send_bfr_pre_green or
	stage_name == self.stages.wipe_bfr_pre_green then
	
		if stage_name == self.stages.wipe_bfr_pre_green
		then self.happy_end = true
		else self.happy_end = false end
		
		start_timer_to_black_screen()
		
	elseif stage_name == self.stages.send_bfr_green or
	stage_name == self.stages.wipe_bfr_green then
		self:create_signal
		(
			flr(480/2+0.5)-(8+9),
			8*3+9,
			27,
			"sierra, it's ch4rlie two-three. quaran7ine time is up. please re5p0nd. over.",
			self.stages.bfr_xport,
			self.stages.send_bfr_orange,
			self.stages.wipe_bfr_orange
		)
	elseif stage_name == self.stages.send_bfr_orange or
	stage_name == self.stages.wipe_bfr_orange then
		if self.happy_end then
			self:create_signal
			(
				8+9,
				flr(270/2+0.5)-(8+9),
				9,
				"i7s si3rra one-one. i sp1ced the fe3d; we did th1s charl1e!!",
				self.stages.bfr_xport,
				self.stages.send_bfr_last,
				self.stages.wipe_bfr_last
			)
		else
			self:create_signal
			(
				8+9,
				flr(270/2+0.5)-(8+9),
				9,
				"s1erra, it's charlie two-three. resp0nd-respond plea5e!",
				self.stages.bfr_xport,
				self.stages.send_bfr_last,
				self.stages.wipe_bfr_last
			)
		end
	elseif stage_name == self.stages.send_bfr_last or
	stage_name == self.stages.wipe_bfr_last then
		if self.happy_end then
			self:create_signal
			(
				flr(480/2/2+0.5),
				flr(270/2/2+0.5),
				28,
				"it's charl1e two-three, thank god. you're alive. y0u did this. over.",
				self.stages.bfr_xport,
				self.stages.send_bfr_xport,
				self.stages.wipe_bfr_xport
			)
		else
			self:create_signal
			(
				flr(480/2/2+0.5),
				flr(270/2/2+0.5),
				2,
				"sierra, respond pl345e!!! n0 no no no. god, please no. be9 #0u n# ##",
				self.stages.bfr_xport,
				self.stages.send_bfr_xport,
				self.stages.wipe_bfr_xport
			)
		end
	elseif stage_name == self.stages.send_bfr_xport or
	stage_name == self.stages.wipe_bfr_xport then
		local l = "l"
	end
end
function source:send_message(letter)
	for l in all(data.letters) do
	l.indx += 1
	end
	message:new
	(
		payout_node_canvas,
		{
			x=0,
			y=0,
			z=10
		},
		1,
		{letter}
	)
	save_data.num_of_letters += 1
	add(save_data.letter_mrk_vals, tostring(dt()))
	add(save_data.letter_amount_vals, -1)
	add(save_data.letter_lbl_vals, letter)
	add(save_data.letter_is_active_vals, nil)
	store(save_file, save_data)
end
function source:send_compensation(letter)
	for l in all(data.letters) do
	l.indx += 1
	end
	compensation:new
	(
		payout_node_canvas,
		{
			x=0,
			y=0,
			z=10
		},
		1,
		save_data.compensation,
		{letter}
	)
	save_data.num_of_letters += 1
	add(save_data.letter_mrk_vals, tostring(dt()))
	add(save_data.letter_amount_vals, save_data.compensation)
	add(save_data.letter_lbl_vals, letter)
	add(save_data.letter_is_active_vals, true)
	store(save_file, save_data)
end
function source:send_bonus(letter)
	for l in all(data.letters) do
	l.indx += 1
	end
	compensation:new
	(
		payout_node_canvas,
		{
			x=0,
			y=0,
			z=10
		},
		1,
		save_data.compensation*3,
		{letter}
	)
	save_data.num_of_letters += 1
	add(save_data.letter_mrk_vals, tostring(dt()))
	add(save_data.letter_amount_vals, save_data.compensation*3)
	add(save_data.letter_lbl_vals, letter)
	add(save_data.letter_is_active_vals, true)
	store(save_file, save_data)
end
function source:promote()
	self:send_message(self.lets.promoted)
	main_char.row_indx = 1
	main_char.lt_open.index = 208;
	main_char.lt_clsd.index = 209;
	main_char.rt_open.index = 210;
	main_char.rt_clsd.index = 211;
	main_char.dn_open.index = 212;
	main_char.dn_clsd.index = 213;
	main_char.up_open.index = 214;
	main_char.up_clsd.index = 215;
	main_char.lt_dn.index = 216;
	main_char.lt_up.index = 217;
	main_char.rt_dn.index = 218;
	main_char.rt_up.index = 219;
	main_char.name = "mgr-04"
	spawn_opr93()
	
	save_data.row_indx = 1
	save_data.name = "mgr-04"
	save_data.compensation = 100
	store(save_file, save_data)
end
function source:create_signal(x, y, clr, txt, collect_bfr, send_bfr, wipe_bfr)
	signal:new
	(
		{
			x=x,
			y=y,
			z=-main_char_y
		},
		clr,
		txt,
		collect_bfr,
		send_bfr,
		wipe_bfr
	)
end
