--[[pod_format="raw",created="2026-04-13 09:54:49",modified="2026-04-14 22:31:00",revision=138]]
local primary_key_col = 17
local secondary_key_col = 19
local cls_btn_primary_col = 17
local cls_btn_secondary_col = 19
local key_z_pos = -20
local function bs_text(str)
    if not str or #str == 0 then return "" end
    local i = #str
    while i > 1 and (ord(str, i) & 0xc0) == 0x80 do
        i = i - 1
    end
    return sub(str, 1, i - 1)
end

