--[[pod_format="raw",created="2026-04-09 02:42:10",modified="2026-04-18 04:35:04",revision=27]]
--xtras--
function clone(t)
	local t2 = {}
	for k, v in pairs(t) do
		t2[k] = v
	end
	return t2
end

function are_equal(t, t2)
 local result = true
 for k, v in pairs(t) do
		if t[k] != t2[k]
		then result = false end
	end
 for k, v in pairs(t2) do
		if t[k] != t2[k]
		then result = false end
	end
	return result
end

function d(num_of_edges)
 return flr(rnd(num_of_edges))
end

function sort_sprites(arr)
 for i=2,#arr do
  local val = arr[i]
  local j = i - 1
  while j > 0 and arr[j]:pos().z < val:pos().z do
   arr[j+1] = arr[j]
   j -= 1
  end
  arr[j+1] = val
 end
end
:: ui/button.lua
--[[pod_format="raw",created="2026-04-22 14:18:47",modified="2026-04-22 14:25:02",revision=24]]
button = {}
button.__index = button
function button:new(cnvs, pos, offset, w, h, act, col, lbl, lbl_col, is_active)
	local instance = {}
	cnvs:add_el(instance)
	instance.pos = pos
	instance.offset = offset
	instance.w = w
	instance.h = h
	instance.act = act
	if col == nil then
		instance.col = primary_color
	else
		instance.col = col
	end
	instance.lbl = lbl
	if lbl_col == nil then
		instance.lbl_col = secondary_color
	else
		instance.lbl_col = lbl_col
	end
	if is_active == nil then
		instance.is_active = true
	else
		instance.is_active = is_active
	end
	if instance.is_active == false then
		if col == nil then
			instance.col = secondary_color end
		if lbl_col == nil then
			instance.lbl_col = primary_color end
	end
	add(data.elements, instance)
	add(data.buttons, instance)
	setmetatable(instance, button)
	return instance
end
function button:x()
	return self.pos.x + self.offset.x
end
function button:y()
	return self.pos.y + self.offset.y
end
function button:hover()
	local mx, my, mb = mouse()
	if self:x() <= mx and
	mx <= self:x() + self.w and
	self:y() <= my and
	my <= self:y() + self.h then
			return true
	end
	return false
end
function button:hold()
	local mx, my, mb = mouse()
	if self:hover() and mb > 0 then
		return true
	end
	return false
end
function button:pushed()
	if not self.is_active then return end
	local mx, my, mb = mouse()
	if
		prev_mb == 0 and self:hold() then return true
	end
	return false
end
function button:update()
end
function button:draw()
	--inactive
	if self.is_active == false then
		--stroke
		rectfill
		(
			self:x(),
			self:y(),
			self:x()+self.w-1,
			self:y()+self.h-1,
			self.lbl_col
		)
		--fill
		rectfill
		(
			self:x()+1,
			self:y()+1,
			self:x()+self.w-2,
			self:y()+self.h-2,
			self.col
		)
		--name
		if self.lbl then
			write
			(
				self.lbl[1],
				self:x()+2,
				self:y()+2,
				self.lbl_col
			)
		end
	end
	--active-idle
	if self.is_active == true and not self:hover() then
		--stroke
		rectfill
		(
			self:x(),
			self:y(),
			self:x()+self.w-1,
			self:y()+self.h-1,
			self.lbl_col
		)
		--top
		rectfill
		(
			self:x()+1,
			self:y()+1,
			self:x()+self.w-2,
			self:y()+1+6,
			self.col
		)
		--side
		rectfill
		(
			self:x()+1,
			self:y()+1+8,
			self:x()+self.w-2,
			self:y()+self.h-2,
			self.col
		)
		--name
		if self.lbl then
			write
			(
				self.lbl[1],
				self:x()+2,
				self:y()+2,
				self.lbl_col
			)
		end
	end
	--active-hover
	if self.is_active == true and self:hover() and not self:hold() then
		--stroke
		rectfill
		(
			self:x(),
			self:y(),
			self:x()+self.w-1,
			self:y()+self.h-1,
			self.lbl_col
		)
		--top
		rectfill
		(
			self:x()+1,
			self:y()+1,
			self:x()+self.w-2,
			self:y()+1+6,
			7
		)
		--side
		rectfill
		(
			self:x()+1,
			self:y()+1+8,
			self:x()+self.w-2,
			self:y()+self.h-2,
			7
		)
		--name
		if self.lbl then
			write
			(
				self.lbl[1],
				self:x()+2,
				self:y()+2,
				self.lbl_col
			)
		end
	end
	--active-pushed
	if self.is_active == true and self:hold() then
		--stroke
		rectfill
		(
			self:x(),
			self:y(),
			self:x()+self.w-1,
			self:y()+self.h-1,
			self.lbl_col
		)
		--top
		rectfill
		(
			self:x()+1,
			self:y()+1+4,
			self:x()+self.w-2,
			self:y()+1+6+4,
			7
		)
		--side
		rectfill
		(
			self:x()+1,
			self:y()+1+8+4,
			self:x()+self.w-2,
			self:y()+self.h-2,
			7
		)
		--name
		if self.lbl then
			write
			(
				self.lbl[1],
				self:x()+2,
				self:y()+2+4,
				self.lbl_col
			)
		end
	end
end
function button:disable()
	self.is_active = false
	if self.col == primary_color then
		self.col = secondary_color end
	if self.lbl_col == secondary_color then
		self.lbl_col = primary_color end
end
function button:destroy()
	if type(t) ~= "table" then return end
    
	for k, v in pairs(t) do
		if type(v) == "table" then
			destroy_table(v)
			end
		t[k] = nil
	end
end
:: ui/nice_text.lua
--[[pod_format="raw",created="2026-04-19 02:01:05",modified="2026-04-19 02:54:12",revision=164]]
nice_text = {}
nice_text.__index = nice_text

function nice_text:new(cnvs, x, y, txt)
    local instance = {}
    cnvs:add_el(instance)
    instance.pos =
    {
    	x=x-(flr(#txt/2+0.5)*4),
    	y=y,
    	z=-200
    }
    instance.txt = txt
    instance.frame_index = 0
    instance.speed = 1
    instance.deleted = false
    instance.clr = 7
    return setmetatable(instance, nice_text)
end

function nice_text:update()
	if self.deleted then return end
	self.frame_index += self.speed
	if self.frame_index > 300 then
		self.deleted = true
	end
	self.clr += 1
	if self.clr > 12 then
		self.clr = 7
	end
end

function nice_text:draw()
	if self.deleted then return end
    local oy = -(self.frame_index / 2)
    write(self.txt, self.pos.x, self.pos.y + oy, self.clr)
end
