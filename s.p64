--[[pod_format="raw",created="2026-04-09 02:40:28",modified="2026-04-09 02:40:28",revision=0]]
--object--

object = {}
object.__index = object
function object:new
(grid_pos, collider)
 local instance = {}
 instance.grid_pos = grid_pos
 instance.animator =
 animator:new
 (
  grid_pos,
  {
   x=0,
   y=0,
   z=0
  }
 )
 instance.collider = collider
 setmetatable(instance, object)
 add(objects, instance)
 return instance
end

function object:set_pos(new_pos)
 self.grid_pos = new_pos
end

function object:move(vector3)
 self.grid_pos.x += vector3.x
 self.grid_pos.y += vector3.y
 self.grid_pos.z += vector3.z
end

function object:move_lt_up()
 self:move
	 (
	  {
	   x=-1,
	   y=-1,
	   z=1
	  }
	 )
end

function object:move_lt()
 self:move
  (
   {
    x=-1,
    y=0,
    z=0
   }
  )
end

function object:move_lt_dn()
 self:move
	 (
	  {
	   x=-1,
	   y=1,
	   z=-1
	  }
	 )
end

function object:move_up()
 self:move
  (
   {
    x=0,
    y=-1,
    z=1
   }
  )
end

function object:move_dn()
 self:move
  (
   {
    x=0,
    y=1,
    z=-1
   }
  )
end

function object:move_rt_up()
 self:move
	 (
	  {
	   x=1,
	   y=-1,
	   z=1
	  }
	 )
end

function object:move_rt()
 self:move
  (
   {
    x=1,
    y=0,
    z=0
   }
  )
end

function object:move_rt_dn()
 self:move
	 (
	  {
	   x=1,
	   y=1,
	   z=-1
	  }
	 )
end

function object:col_check()
 return self.collider:check()
end
